# ============================================
# GoToMarry 备婚管理系统 - 环境变量模板
# 复制此文件为 .env 并填入实际值
# ============================================

# 鉴权配置（请修改为生产环境使用的密钥）
JWT_SECRET=your-secret-key-here
PIN_CODE=your-pin-code-here

# 服务端口
NODE_PORT=3000

# 总预算上限
BUDGET_TOTAL=300000

# Vite 前端环境变量
VITE_GROOM_NAME=Groom Name
VITE_BRIDE_NAME=Bride Name
VITE_WEDDING_DATE=YYYY-MM-DD
